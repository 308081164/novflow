# DeepSeek API
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 认证
JWT_SECRET=change-me-in-production
DEMO_EMAIL=demo@example.com
DEMO_PASSWORD=demo123456

# 本地开发（默认 SQLite，正文存 DB）
DATABASE_URL=sqlite:///./data/novflow.db
USE_MINIO=false

# MinIO（Docker 部署时 compose 会自动覆盖为 true）
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=novflow
MINIO_SECRET_KEY=novflowsecret
MINIO_BUCKET=novflow-chapters
MINIO_SECURE=false

# PostgreSQL（Docker 部署时使用，本地可忽略）
POSTGRES_USER=novflow
POSTGRES_PASSWORD=novflow
POSTGRES_DB=novflow

# CORS（开发模式 Vite 代理）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000
